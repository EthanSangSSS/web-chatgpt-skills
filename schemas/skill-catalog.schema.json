{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EthanSangSSS/web-chatgpt-skills/schemas/skill-catalog.schema.json",
  "title": "Web ChatGPT Skill Catalog",
  "type": "object",
  "required": ["version", "updated_at", "repository", "purpose", "execution_defaults", "skills"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "updated_at": { "type": "string" },
    "repository": { "type": "string" },
    "purpose": { "type": "string" },
    "execution_defaults": {
      "type": "object",
      "required": ["local_terminal", "local_filesystem", "background_work", "secrets_handling", "evidence_rule", "handoff_rule"],
      "additionalProperties": false,
      "properties": {
        "local_terminal": { "enum": ["prohibited", "optional", "available"] },
        "local_filesystem": { "enum": ["prohibited", "optional", "available"] },
        "background_work": { "enum": ["prohibited", "optional", "available"] },
        "secrets_handling": { "type": "string" },
        "evidence_rule": { "type": "string" },
        "handoff_rule": { "type": "string" }
      }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "path", "status", "priority", "category", "triggers", "do_not_use_for"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "path": { "type": "string", "pattern": "^[a-z0-9-]+/SKILL\\.md$" },
          "status": { "enum": ["draft", "beta", "stable", "deprecated"] },
          "priority": { "enum": ["P0", "P1", "P2", "P3"] },
          "category": { "type": "string" },
          "triggers": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "do_not_use_for": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
